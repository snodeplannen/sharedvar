# Clangd configuration for SharedValueV3_MemMap C++ Producer
# Relative paths are resolved from this file's location (cpp_core/)
#
# PREREQUISITE: Run 'cmake -B build -S .' first so FetchContent downloads the headers.

CompileFlags:
  Compiler: clang-cl
  Add:
    - "/std:c++20"
    - "/EHsc"
    - "-fexceptions"
    - "-fcxx-exceptions"
    - "-DNOMINMAX"
    - "-DWIN32_LEAN_AND_MEAN"
    - "-D_WIN32"
    - "-DWIN32"
    # FlatBuffers headers (downloaded by CMake FetchContent into build/_deps/)
    - "-isystem"
    - "build/_deps/flatbuffers-src/include"
    # Project source directory (SharedValueEngine.hpp, dataset_generated.h)
    - "-I"
    - "."
    # MSVC Standard Library (these must remain absolute - external SDK paths)
    - "-isystem"
    - "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Tools\\MSVC\\14.44.35207\\include"
    - "-isystem"
    - "C:\\Program Files\\Microsoft Visual Studio\\2022\\Enterprise\\VC\\Tools\\MSVC\\14.44.35207\\include"
    # Windows SDK
    - "-isystem"
    - "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\ucrt"
    - "-isystem"
    - "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\um"
    - "-isystem"
    - "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\shared"

Diagnostics:
  UnusedIncludes: None
  Suppress:
    - "*fe_expected_compiler_job*"
