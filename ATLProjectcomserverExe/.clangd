# Clangd configuration for ATLProjectcomserverExe
# Relative paths are resolved from this file's location (ATLProjectcomserverExe/)

CompileFlags:
  Compiler: clang-cl
  Add:
    - "/std:c++20"
    - "/EHsc"
    - "-fexceptions"
    - "-fcxx-exceptions"
    - "-DUNICODE"
    - "-D_UNICODE"
    - "-D_WIN32"
    - "-DWIN32"
    - "-DNOMINMAX"
    - "-DWIN32_LEAN_AND_MEAN"
    # MSVC Standard Library (external - must be absolute)
    - "-isystem"
    - "C:\\Program Files\\Microsoft Visual Studio\\2022\\Enterprise\\VC\\Tools\\MSVC\\14.44.35207\\include"
    - "-isystem"
    - "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Tools\\MSVC\\14.44.35207\\include"
    # ATL/MFC headers (required for ATL COM project)
    - "-isystem"
    - "C:\\Program Files\\Microsoft Visual Studio\\2022\\Enterprise\\VC\\Tools\\MSVC\\14.44.35207\\atlmfc\\include"
    - "-isystem"
    - "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Tools\\MSVC\\14.44.35207\\atlmfc\\include"
    # Windows SDK (external - must be absolute)
    - "-isystem"
    - "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\ucrt"
    - "-isystem"
    - "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\um"
    - "-isystem"
    - "C:\\Program Files (x86)\\Windows Kits\\10\\Include\\10.0.26100.0\\shared"
    # Project includes (relative)
    - "-I"
    - "."
    - "-I"
    - "../SharedValueV2/include"
    - "-I"
    - "x64/Release"

Diagnostics:
  UnusedIncludes: None
  Suppress:
    - "*fe_expected_compiler_job*"
