// ATLProject-comserver.idl : IDL source for ATLProject-comserver
import "oaidl.idl";
import "ocidl.idl";

// MathOperations interface
[
    object,
        uuid(488e9f3c-299b-4fe1-8b25-a2b9c2a23506),
        dual,
        nonextensible,
        pointer_default(unique)
]
interface IMathOperations : IDispatch
{
    HRESULT Add([in] DOUBLE a, [in] DOUBLE b, [out, retval] DOUBLE* result);
    HRESULT Subtract([in] DOUBLE a, [in] DOUBLE b, [out, retval] DOUBLE* result);
    HRESULT Multiply([in] DOUBLE a, [in] DOUBLE b, [out, retval] DOUBLE* result);
    HRESULT Divide([in] DOUBLE a, [in] DOUBLE b, [out, retval] DOUBLE* result);
};

// SharedValueCallback interface (backward compatible)
[
    object,
        uuid(e7639719-258c-46a3-b349-c3c96ac4b46c),
        dual,
        nonextensible,
        pointer_default(unique)
]
interface ISharedValueCallback : IDispatch
{
    [id(1)] HRESULT OnValueChanged([in] VARIANT newValue);
    [id(2)] HRESULT OnDateTimeChanged([in] BSTR newDateTime);
};

// EventCallback interface (new, rich mutation events)
[
    object,
        uuid(a3f1d8e2-7c4b-4a9e-b5d6-1e2f3a4b5c6d),
        dual,
        nonextensible,
        pointer_default(unique)
]
interface IEventCallback : IDispatch
{
    [id(1)] HRESULT OnMutationEvent(
        [in] LONG eventType,
        [in] BSTR key,
        [in] BSTR oldValue,
        [in] BSTR newValue,
        [in] BSTR source,
        [in] BSTR timestamp,
        [in] LONG sequenceId
    );
};

// SharedValue interface (updated with event callback registration)
[
    object,
        uuid(aced7d5d-0559-4e35-a972-42d9871ee14a),
        dual,
        nonextensible,
        pointer_default(unique)
]
interface ISharedValue : IDispatch
{
    HRESULT SetValue([in] VARIANT value);
    HRESULT GetValue([out, retval] VARIANT* value);
    HRESULT GetCurrentUTCDateTime([out, retval] BSTR* dateTime);
    HRESULT GetCurrentUserLogin([out, retval] BSTR* login);
    HRESULT LockSharedValue([in] LONG timeoutMs);
    HRESULT Unlock();
    HRESULT Subscribe([in] ISharedValueCallback* callback);
    HRESULT Unsubscribe([in] ISharedValueCallback* callback);
    [id(10)] HRESULT RegisterEventCallback([in] IEventCallback* callback);
    [id(11)] HRESULT UnregisterEventCallback([in] IEventCallback* callback);
};

// DatasetProxy interface (new)
[
    object,
        uuid(d4e5f6a7-b8c9-4d0e-a1b2-c3d4e5f6a7b8),
        dual,
        nonextensible,
        pointer_default(unique)
]
interface IDatasetProxy : IDispatch
{
    // Storage Mode
    [id(1)] HRESULT SetStorageMode([in] LONG mode);
    [id(2)] HRESULT GetStorageMode([out, retval] LONG* mode);

    // CRUD
    [id(10)] HRESULT AddRow([in] BSTR key, [in] BSTR value);
    [id(11)] HRESULT GetRowData([in] BSTR key, [out, retval] BSTR* data);
    [id(12)] HRESULT UpdateRow([in] BSTR key, [in] BSTR value, [out, retval] VARIANT_BOOL* success);
    [id(13)] HRESULT RemoveRow([in] BSTR key, [out, retval] VARIANT_BOOL* success);
    [id(14)] HRESULT Clear();

    // Query
    [id(20)] HRESULT GetRecordCount([out, retval] LONG* count);
    [id(21)] HRESULT HasKey([in] BSTR key, [out, retval] VARIANT_BOOL* exists);

    // Paginering
    [id(30)] HRESULT FetchPageKeys([in] LONG startIndex, [in] LONG limit, [out, retval] VARIANT* keys);
    [id(31)] HRESULT FetchPageData([in] LONG startIndex, [in] LONG limit, [out, retval] VARIANT* keysAndValues);

    // Event Callbacks
    [id(40)] HRESULT RegisterEventCallback([in] IEventCallback* callback);
    [id(41)] HRESULT UnregisterEventCallback([in] IEventCallback* callback);
};

// Library definition
[
    uuid(86be8df9-669e-4443-b1a0-bd69ea9e40cc),
        version(1.0)
]
library ATLProjectcomserverLib
{
    importlib("stdole2.tlb");

    [
        uuid(b97b4532-1222-4229-a090-d625c1e9532b)
    ]
        coclass MathOperations
    {
        [default] interface IMathOperations;
    };

    [
        uuid(6818dd57-f9e6-45be-aa20-ea4b5b658af3)
    ]
        coclass SharedValueCallback
    {
        [default] interface ISharedValueCallback;
    };

    [
        uuid(71ef033e-e1b5-4985-bc7b-7687426bbdbb)
    ]
        coclass SharedValue
    {
        [default] interface ISharedValue;
    };

    [
        uuid(c1d2e3f4-a5b6-4c7d-8e9f-0a1b2c3d4e5f)
    ]
        coclass DatasetProxy
    {
        [default] interface IDatasetProxy;
    };
};

import "shobjidl.idl";